# Public build-time values
VITE_APP_ENV=local
VITE_PUBLIC_ORIGIN=http://localhost:5173
VITE_PROTOCOL_VERSION=1

# Cloudflare binding names are configured in wrangler.jsonc.
# Secrets must be set with Wrangler, not committed:
#
# pnpm wrangler secret put NETWORK_BUCKET_SECRET
# pnpm wrangler secret put INVITATION_SIGNING_SECRET
# pnpm wrangler secret put RECOVERY_TRANSFER_SECRET
